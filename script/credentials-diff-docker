#!/usr/bin/env sh
set -e
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"
if [ -z "$1" ]; then
echo "Usage: textconv <path>" >&2
exit 1
fi
INPUT_FILE="$1"
# リポジトリ内のパスならそのままコンテナ内パスに変換
case "$INPUT_FILE" in
"$ROOT"/*)
REL_PATH="${INPUT_FILE#$ROOT/}"
CONTAINER_PATH="/rails/$REL_PATH"
;;
*)
# Git の一時ファイルなど: リポジトリ内にコピーしてから渡す
TMPFILE=$(mktemp -p "$ROOT" credentials_diff.XXXXXXXXXX)
cat "$INPUT_FILE" > "$TMPFILE"
REL_PATH="${TMPFILE#$ROOT/}"
CONTAINER_PATH="/rails/$REL_PATH"
trap 'rm -f "$TMPFILE"' EXIT
;;
esac
docker compose run --rm -T web bin/rails credentials:diff "$CONTAINER_PATH"
